<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="240"
        x:Class="ElectricFox.CobraUi.WindowsHost.MainWindow"
		Loaded="Control_OnLoaded" Width="320" Height="240"
        Title="ElectricFox.CobraUi.WindowsHost">
	<Grid>
		<Image x:Name="Display"
			   Stretch="None"
			   HorizontalAlignment="Left"
			   VerticalAlignment="Top" Width="320" Height="240" />

	</Grid>

</Window>
